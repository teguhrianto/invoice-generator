# Override the static USD → IDR fallback exchange rate shown in invoice notes.
# Must be a positive number. Defaults to 16000 if absent or non-numeric.
# NEXT_PUBLIC_IDR_RATE=16000

# Canonical URL used in sitemap.xml, robots.txt, and Open Graph tags.
# NEXT_PUBLIC_SITE_URL=https://invoice-generator.teguhrianto.com
